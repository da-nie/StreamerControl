####### Compile

main.o: ../StreamerControl/main.cpp ../StreamerControl/cmainwindow.h \
		../StreamerControl/cstreamer.h \
		../StreamerControl/ccommand.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o main.o ../StreamerControl/main.cpp

cmainwindow.o: ../StreamerControl/cmainwindow.cpp ../StreamerControl/cmainwindow.h \
		../StreamerControl/cstreamer.h \
		../StreamerControl/ccommand.h \
		ui_cmainwindow.h \
		../StreamerControl/system/system.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o cmainwindow.o ../StreamerControl/cmainwindow.cpp

cmutex.o: ../StreamerControl/system/cmutex.cpp ../StreamerControl/system/cmutex.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o cmutex.o ../StreamerControl/system/cmutex.cpp

cthread.o: ../StreamerControl/system/cthread.cpp ../StreamerControl/system/cthread.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o cthread.o ../StreamerControl/system/cthread.cpp

system.o: ../StreamerControl/system/system.cpp ../StreamerControl/system/system.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o system.o ../StreamerControl/system/system.cpp

cstreamer.o: ../StreamerControl/cstreamer.cpp ../StreamerControl/cstreamer.h \
		../StreamerControl/ccommand.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o cstreamer.o ../StreamerControl/cstreamer.cpp

ccommand.o: ../StreamerControl/ccommand.cpp ../StreamerControl/ccommand.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o ccommand.o ../StreamerControl/ccommand.cpp

ccassete.o: ../StreamerControl/ccassete.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o ccassete.o ../StreamerControl/ccassete.cpp

cfile.o: ../StreamerControl/cfile.cpp ../StreamerControl/cfile.h
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o cfile.o ../StreamerControl/cfile.cpp

crecord.o: ../StreamerControl/crecord.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o crecord.o ../StreamerControl/crecord.cpp

moc_cmainwindow.o: moc_cmainwindow.cpp 
	$(CXX) -c $(CXXFLAGS) $(INCPATH) -o moc_cmainwindow.o moc_cmainwindow.cpp

